---
interface Props {
  title?: string;
  cwd?: string;
}
const { title = 'terminal', cwd = '~' } = Astro.props;
---

<div class="term" data-cwd={cwd}>
  <div class="term-bar">
    <span class="dot dot-r"></span>
    <span class="dot dot-y"></span>
    <span class="dot dot-g"></span>
    <span class="term-title">{title}</span>
  </div>
  <div class="term-screen">
    <div class="term-output"><slot /></div>
    <div class="tline term-inputline">
      <span class="term-prompt"></span><input
        class="term-input"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        autocorrect="off"
        spellcheck="false"
        aria-label="terminal input"
      />
    </div>
  </div>
</div>

<style>
  .term {
    background: var(--bg-elev-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 12px 40px -16px rgba(0, 0, 0, 0.6);
  }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    background: var(--bg-elev);
    border-bottom: 1px solid var(--border);
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    display: inline-block;
  }
  .dot-r {
    background: #ff5f56;
  }
  .dot-y {
    background: #ffbd2e;
  }
  .dot-g {
    background: #27c93f;
  }
  .term-title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-faint);
  }
  .term-screen {
    margin: 0;
    padding: 18px;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--fg);
    max-height: 360px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-word;
    cursor: text;
  }
  .term-inputline {
    display: flex;
    align-items: baseline;
  }
  .term-prompt {
    white-space: pre;
  }
  .term-input {
    flex: 1 1 auto;
    min-width: 0;
    background: transparent;
    border: 0;
    outline: 0;
    padding: 0;
    margin: 0;
    color: var(--fg);
    font: inherit;
    caret-color: var(--accent);
  }
</style>

<script>
  import '../scripts/term/terminal';
</script>
